# Telegram
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN
WEBHOOK_URL=https://your-public-domain.example.com/webhook/telegram
TELEGRAM_CHAT_ID=YOUR_TELEGRAM_CHAT_ID

# Gemini
GEMINI_API_KEY=YOUR_GEMINI_API_KEY
GEMINI_MODEL=gemini-2.5-flash

# Gmail SMTP/IMAP
MAIL_USERNAME=your-gmail@gmail.com
MAIL_PASSWORD=YOUR_GMAIL_APP_PASSWORD
MAIL_FROM=Appraiser Name
MAIL_TO=receiver@example.com
MAIL_CC=cc1@example.com,cc2@example.com

# Optional aliases
SMTP_SERVER=smtp.gmail.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_MAILBOX=INBOX

# SQLite
TELEGRAM_RECORDS_DB=data/telegram_records.db
TELEGRAM_CASES_DB=data/cases.db

# Listener
MAIL_LISTENER_CC=hostktpro@gmail.com
MAIL_LISTENER_SUBJECT_FILTER=

# Telegram uploads
TELEGRAM_UPLOAD_DIR=data/uploads
